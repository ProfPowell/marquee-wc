{
  "name": "@profpowell/marquee-wc",
  "version": "1.2.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "A vanilla JavaScript web component: the <marquee> tag reborn for 2026 — accessible, themeable, constant-velocity, and Vanilla Breeze aware",
  "type": "module",
  "main": "dist/marquee-wc.js",
  "module": "dist/marquee-wc.js",
  "types": "marquee-wc.d.ts",
  "exports": {
    ".": {
      "types": "./marquee-wc.d.ts",
      "import": "./dist/marquee-wc.js"
    },
    "./style.css": "./dist/marquee-wc.css",
    "./marquee-wc.css": "./dist/marquee-wc.css"
  },
  "files": [
    "dist",
    "marquee-wc.d.ts"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && cp src/marquee-wc.css dist/marquee-wc.css && cp dist/marquee-wc.js dist/marquee-wc.js.map docs/ && cp src/marquee-wc.css docs/marquee-wc.css",
    "preview": "vite preview",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "analyze": "cem analyze",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "web-component",
    "custom-element",
    "marquee",
    "ticker",
    "scroller",
    "vanilla-breeze",
    "retro",
    "animation"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.10.3",
    "@playwright/test": "^1.48.0",
    "eslint": "^9.12.0",
    "prettier": "^3.3.3",
    "vite": "^5.4.8"
  },
  "customElements": "custom-elements.json"
}
